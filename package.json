{
  "name": "@emperor/opencode-pipeline",
  "version": "0.1.0",
  "description": "Cost-efficient multi-agent development pipeline plugin for OpenCode",
  "author": "Emperor",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "bun run script/build.ts",
    "deploy": "bun run build && bun run script/deploy.ts",
    "uninstall": "bun run script/uninstall.ts",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "pipeline",
    "multi-agent",
    "orchestration"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.15",
    "@opencode-ai/sdk": "^1.3.15"
  },
  "devDependencies": {
    "bun-types": "^1.3.0",
    "typescript": "^5.7.0"
  }
}
